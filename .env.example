# --- Neo4j ---
# Par défaut : le conteneur "neo4j" du docker-compose.yml (tout-en-Docker).
# NEO4J_LOCAL_PASSWORD définit le mot de passe du conteneur local (voir docker-compose.yml).
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=musicgraph123
NEO4J_LOCAL_PASSWORD=musicgraph123
NEO4J_DATABASE=neo4j

# Alternative : Neo4j Aura (cloud). Si vous préférez Aura, commentez les 3 lignes
# ci-dessus et décommentez celles-ci (et supprimez/ignorez le service "neo4j" du
# docker-compose, ou laissez-le tourner en parallèle sans l'utiliser) :
# NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_password_here
# NEO4J_DATABASE=neo4j

# MusicBrainz API
MUSICBRAINZ_API_URL=https://musicbrainz.org/ws/2
MUSICBRAINZ_USER_AGENT=MusicGraph/1.0.0 (adlenssouci03@gmail.com)

# Backend
BACKEND_PORT=3000

# Frontend
VITE_API_URL=http://localhost:3000/api
