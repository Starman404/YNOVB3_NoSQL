# ---------------------------------------------------
# MusicGraph - Variables d'environnement (exemple)
# Copier ce fichier en ".env" et adapter les valeurs
# ---------------------------------------------------

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_strong_password

# --- MusicBrainz API ---
# Documentation: https://musicbrainz.org/doc/MusicBrainz_API
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
# MusicBrainz exige un User-Agent identifiable (nom app / version / contact)
MUSICBRAINZ_USER_AGENT=MusicGraph/1.0.0 (contact@example.com)
# Délai minimum entre deux appels MusicBrainz, en ms (règle: 1 req/s max)
MUSICBRAINZ_RATE_LIMIT_MS=1100

# --- Backend ---
BACKEND_PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Frontend ---
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:4000/api
